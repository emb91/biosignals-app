{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "biosignals-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "biosignals-app-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3001"],
      "port": 3001,
      "env": { "NEXT_DIST_DIR": ".next-preview" }
    },
    {
      "name": "biosignals-app-webpack",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--webpack", "-p", "3002"],
      "port": 3002,
      "env": { "NEXT_DIST_DIR": ".next-webpack" }
    }
  ]
}
